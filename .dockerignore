# Training outputs and large data — excluded to keep build context small
work_dirs/
datasets/
coco/
# Exclude everything under models/ by default, but keep pannuke.pth so it can
# be baked into the image for a zero-download "just docker run" experience.
# To bake other weights, add another `!models/<name>.pth` line here.
models/*
!models/pannuke.pth

# WSI/inference output directories under demo/
demo/wsi/
demo/imgs_infer/
demo/wsi_infer/
demo/wsi_res/

# Python bytecode
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd

# Binary model/data artifacts — too large for the image
**/*.pth
!models/pannuke.pth
**/*.ckpt
**/*.npy
**/*.h5
**/*.svs
**/*.ndpi
**/*.tiff
**/*.tif

# VCS and editor state
.git
.github
.gitignore
.gitattributes
.idea
.vscode
.cursor
.claude
CLAUDE.md

# Logs and experiment tracking
*.log
wandb/

# Build/test caches
*.egg-info
# thirdparty/mmdetection vendored source is KEPT, but exclude its build artefacts
thirdparty/mmdetection/mmdet.egg-info
.pytest_cache
.mypy_cache

# Docker image tarballs (previously-saved images in the repo root)
*.tar.gz
*.tar

# OMC scratch (PRD, progress logs, build watchdog script)
.omc/
